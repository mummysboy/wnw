---
import { getImage } from 'astro:assets';
import paintings from '../data/paintings.json';

const CATEGORIES = [
  { id: 'all', label: 'All Work' },
  { id: 'coast', label: 'Coast & Surf' },
  { id: 'harbors', label: 'Harbors & Boats' },
  { id: 'country', label: 'Hills & Country' },
  { id: 'villages', label: 'Villages & Travels' },
  { id: 'studies', label: 'Studies' },
];
const CAT_LABEL = Object.fromEntries(CATEGORIES.map((c) => [c.id, c.label]));

// Eagerly import every prepared painting so Astro can optimize it at build time.
const assets = import.meta.glob('../assets/paintings/*.jpg', {
  eager: true,
  import: 'default',
});

const items = await Promise.all(
  paintings.map(async (p) => {
    const src = assets[`../assets/paintings/${p.file}`];
    if (!src) throw new Error(`Missing image asset for ${p.file}`);
    const thumb = await getImage({ src, width: 780, format: 'webp', quality: 76 });
    const full = await getImage({ src, width: 1700, format: 'webp', quality: 82 });
    return {
      ...p,
      categoryLabel: CAT_LABEL[p.category] ?? p.category,
      thumb: thumb.src,
      full: full.src,
      w: src.width,
      h: src.height,
    };
  })
);
---

<section id="gallery" class="gallery">
  <div class="wrap">
    <div class="gallery__head reveal">
      <p class="kicker">The Gallery</p>
      <h2>Sixty-six watercolors</h2>
      <hr class="rule rule--center" />
      <p class="gallery__intro">
        A wandering coastline of paintings — from the surf and sea stacks to busy
        harbors, golden hills, and villages near and far. Choose a theme, or take
        in the whole shore.
      </p>
    </div>

    <div class="filters reveal" role="tablist" aria-label="Filter paintings by theme">
      {
        CATEGORIES.map((c, i) => (
          <button
            class:list={['filter', { 'is-active': i === 0 }]}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            data-filter={c.id}
          >
            {c.label}
          </button>
        ))
      }
    </div>

    <div class="grid" id="grid">
      {
        items.map((p, i) => (
          <figure class="card" data-category={p.category} style={`--ar:${p.w}/${p.h}`}>
            <button
              class="card__btn"
              data-full={p.full}
              data-title={p.title}
              data-cat={p.categoryLabel}
              data-index={i}
              aria-label={`View “${p.title}” larger`}
            >
              <img
                src={p.thumb}
                alt={`${p.title} — watercolor by Wade Norman`}
                width={p.w}
                height={p.h}
                loading={i < 6 ? 'eager' : 'lazy'}
                decoding="async"
              />
              <figcaption class="card__cap">
                <span class="card__title">{p.title}</span>
                <span class="card__cat">{p.categoryLabel}</span>
              </figcaption>
            </button>
          </figure>
        ))
      }
    </div>
    <p class="gallery__empty" hidden>No paintings in this theme yet.</p>
  </div>

  {/* Lightbox */}
  <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Painting viewer">
    <button class="lb__close" id="lbClose" aria-label="Close viewer">&times;</button>
    <button class="lb__nav lb__prev" id="lbPrev" aria-label="Previous painting">&#8249;</button>
    <figure class="lb__stage">
      <img id="lbImg" src="" alt="" />
      <figcaption class="lb__cap">
        <span id="lbTitle" class="lb__title"></span>
        <span id="lbCat" class="lb__catline"></span>
      </figcaption>
    </figure>
    <button class="lb__nav lb__next" id="lbNext" aria-label="Next painting">&#8250;</button>
  </div>
</section>

<style>
  .gallery {
    background: var(--paper-warm);
  }
  .gallery__head {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
  }
  .gallery__intro {
    color: var(--ink-muted);
    font-size: 1.12rem;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 0.6rem;
    margin: 2.4rem 0 3rem;
  }
  .filter {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--ink-muted);
    background: transparent;
    border: 1px solid var(--ink-soft);
    border-radius: 100px;
    padding: 0.5em 1.15em;
    cursor: pointer;
    transition:
      color 0.25s var(--ease),
      background 0.25s var(--ease),
      border-color 0.25s var(--ease);
  }
  .filter:hover {
    color: var(--terracotta-deep);
    border-color: var(--terracotta);
  }
  .filter.is-active {
    color: var(--paper);
    background: var(--terracotta-deep);
    border-color: var(--terracotta-deep);
  }

  /* masonry via CSS columns — respects each painting's own proportions */
  .grid {
    column-count: 3;
    column-gap: 1.5rem;
  }
  @media (max-width: 900px) {
    .grid {
      column-count: 2;
      column-gap: 1rem;
    }
  }
  @media (max-width: 560px) {
    .grid {
      column-count: 1;
    }
  }

  .card {
    margin: 0 0 1.5rem;
    break-inside: avoid;
  }
  .card[hidden] {
    display: none;
  }
  .card__btn {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: #fdfaf3;
    cursor: pointer;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 10px 24px -16px rgba(43, 41, 36, 0.55);
    transition:
      transform 0.4s var(--ease),
      box-shadow 0.4s var(--ease);
  }
  .card__btn img {
    width: 100%;
    height: auto;
    display: block;
    transition: filter 0.4s var(--ease);
  }
  .card__btn:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 38px -18px rgba(43, 41, 36, 0.6);
  }

  .card__cap {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    text-align: left;
    padding: 0.7rem 0.85rem 0.85rem;
  }
  .card__title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-style: italic;
    color: var(--ink);
    line-height: 1.2;
  }
  .card__cat {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--terracotta);
  }

  .gallery__empty {
    text-align: center;
    color: var(--ink-muted);
    font-style: italic;
    margin-top: 2rem;
  }

  /* ---- lightbox ---- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    gap: clamp(0.5rem, 2vw, 2rem);
    padding: clamp(1rem, 4vw, 3rem);
    background: rgba(28, 26, 22, 0.92);
    backdrop-filter: blur(3px);
  }
  .lightbox.is-open {
    display: flex;
  }
  .lb__stage {
    margin: 0;
    max-width: min(1200px, 92vw);
    max-height: 88vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .lb__stage img {
    max-width: 100%;
    max-height: 78vh;
    width: auto;
    height: auto;
    object-fit: contain;
    background: #fdfaf3;
    padding: clamp(0.5rem, 1.5vw, 1rem);
    border-radius: 2px;
    box-shadow: 0 30px 70px -20px rgba(0, 0, 0, 0.7);
  }
  .lb__cap {
    text-align: center;
    margin-top: 1.1rem;
    color: var(--paper);
  }
  .lb__title {
    display: block;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.5rem;
  }
  .lb__catline {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #d9a066;
  }
  .lb__close,
  .lb__nav {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: var(--paper);
    cursor: pointer;
    border-radius: 50%;
    transition:
      background 0.25s var(--ease),
      transform 0.25s var(--ease);
  }
  .lb__close {
    position: absolute;
    top: clamp(1rem, 3vw, 2rem);
    right: clamp(1rem, 3vw, 2rem);
    width: 46px;
    height: 46px;
    font-size: 1.8rem;
    line-height: 1;
  }
  .lb__nav {
    width: 54px;
    height: 54px;
    font-size: 2rem;
    line-height: 1;
    flex: none;
  }
  .lb__close:hover,
  .lb__nav:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: scale(1.06);
  }
  @media (max-width: 640px) {
    .lb__nav {
      position: absolute;
      bottom: 1.2rem;
      z-index: 2;
    }
    .lb__prev {
      left: 1.2rem;
    }
    .lb__next {
      right: 1.2rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .card__btn:hover {
      transform: none;
    }
  }
</style>

<script>
  // ---- theme filtering ----
  const filters = document.querySelectorAll<HTMLButtonElement>('.filter');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.card'));
  const empty = document.querySelector<HTMLElement>('.gallery__empty');

  function applyFilter(cat: string) {
    let shown = 0;
    cards.forEach((card) => {
      const match = cat === 'all' || card.dataset.category === cat;
      card.hidden = !match;
      if (match) shown++;
    });
    if (empty) empty.hidden = shown !== 0;
  }

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      filters.forEach((b) => {
        b.classList.remove('is-active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-selected', 'true');
      applyFilter(btn.dataset.filter || 'all');
    });
  });

  // ---- lightbox ----
  const lb = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lbImg') as HTMLImageElement;
  const lbTitle = document.getElementById('lbTitle')!;
  const lbCat = document.getElementById('lbCat')!;
  const btns = Array.from(document.querySelectorAll<HTMLButtonElement>('.card__btn'));
  let current = -1;
  let lastFocused: HTMLElement | null = null;

  function visibleButtons() {
    return btns.filter((b) => !(b.closest('.card') as HTMLElement).hidden);
  }

  function show(btn: HTMLButtonElement) {
    lbImg.src = btn.dataset.full || '';
    const title = btn.dataset.title || '';
    lbImg.alt = `${title} — watercolor by Wade Norman`;
    lbTitle.textContent = title;
    lbCat.textContent = btn.dataset.cat || '';
    current = visibleButtons().indexOf(btn);
  }

  function open(btn: HTMLButtonElement) {
    lastFocused = btn;
    show(btn);
    lb.classList.add('is-open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    (document.getElementById('lbClose') as HTMLButtonElement).focus();
  }

  function close() {
    lb.classList.remove('is-open');
    lb.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    lastFocused?.focus();
  }

  function step(dir: number) {
    const vis = visibleButtons();
    if (vis.length === 0) return;
    current = (current + dir + vis.length) % vis.length;
    show(vis[current]);
  }

  btns.forEach((btn) => btn.addEventListener('click', () => open(btn)));
  document.getElementById('lbClose')!.addEventListener('click', close);
  document.getElementById('lbPrev')!.addEventListener('click', () => step(-1));
  document.getElementById('lbNext')!.addEventListener('click', () => step(1));
  lb.addEventListener('click', (e) => {
    if (e.target === lb) close();
  });
  document.addEventListener('keydown', (e) => {
    if (!lb.classList.contains('is-open')) return;
    if (e.key === 'Escape') close();
    else if (e.key === 'ArrowRight') step(1);
    else if (e.key === 'ArrowLeft') step(-1);
  });
</script>
