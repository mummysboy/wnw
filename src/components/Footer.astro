---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap footer__inner">
    <div class="footer__brand">
      <span class="footer__name">State Street Gallery of Fine Art</span>
      <span class="footer__tag">Original paintings · Santa Barbara, California</span>
    </div>

    <nav class="footer__nav" aria-label="Footer">
      <a href="/">The Artists</a>
      <a href="#contact">Purchases</a>
    </nav>
  </div>
  <div class="wrap footer__base">
    <p>© {year} State Street Gallery of Fine Art. All paintings reproduced with the artists’ permission.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: var(--paper);
    padding-block: clamp(3rem, 6vw, 4.5rem) 1.5rem;
  }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1.5rem 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(247, 242, 232, 0.14);
  }
  .footer__name {
    display: block;
    font-family: var(--font-serif);
    font-size: 2rem;
    line-height: 1;
  }
  .footer__tag {
    display: block;
    margin-top: 0.5rem;
    color: rgba(247, 242, 232, 0.65);
    font-size: 0.95rem;
    letter-spacing: 0.03em;
  }
  .footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem;
  }
  .footer__nav a {
    color: rgba(247, 242, 232, 0.82);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    transition: color 0.25s var(--ease);
  }
  .footer__nav a:hover {
    color: #d9a066;
  }
  .footer__base {
    margin-top: 1.4rem;
  }
  .footer__base p {
    margin: 0;
    font-size: 0.82rem;
    color: rgba(247, 242, 232, 0.5);
  }
</style>
