---
import { Image } from 'astro:assets';
import featured from '../assets/paintings/IMG_2408.jpg';
---

<header class="hero">
  <div class="wrap hero__inner">
    <div class="hero__text">
      <p class="kicker">Santa Barbara · Watercolor</p>
      <h1 class="hero__name">Wade&nbsp;Norman</h1>
      <p class="hero__lead">
        Harbors, headlands, and the golden light of the California coast — painted
        in watercolor, from life and from imagination.
      </p>
      <div class="hero__actions">
        <a class="btn" href="#gallery">View the paintings</a>
        <a class="btn btn--ghost" href="#story">Meet the artist</a>
      </div>
    </div>

    <figure class="hero__art">
      <div class="mat">
        <Image
          src={featured}
          alt="Sea Stack at the Point — a watercolor of surf breaking below a coastal headland, by Wade Norman"
          widths={[480, 760, 1000]}
          sizes="(max-width: 900px) 90vw, 520px"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <figcaption>“Sea Stack at the Point” · watercolor</figcaption>
    </figure>
  </div>

  <a class="hero__scroll" href="#story" aria-label="Scroll to read Wade's story">
    <span></span>
  </a>
</header>

<style>
  .hero {
    position: relative;
    padding-block: clamp(2.5rem, 7vw, 5.5rem) clamp(3rem, 7vw, 6rem);
    overflow: hidden;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    min-height: min(78vh, 720px);
  }
  .hero__name {
    font-size: clamp(3.2rem, 9vw, 6.4rem);
    line-height: 0.95;
    margin: 0.1em 0 0.35em;
    letter-spacing: 0.005em;
  }
  .hero__lead {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 2.2vw, 1.85rem);
    font-style: italic;
    line-height: 1.4;
    color: var(--ink-muted);
    max-width: 30ch;
    margin-bottom: 2rem;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  /* framed painting with a paper mat + soft cast shadow */
  .hero__art {
    margin: 0;
  }
  .mat {
    background: #fdfaf3;
    padding: clamp(0.9rem, 2vw, 1.6rem);
    border-radius: var(--radius);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.7) inset,
      0 18px 40px -18px rgba(43, 41, 36, 0.45),
      0 4px 12px -8px rgba(43, 41, 36, 0.3);
    transform: rotate(-0.6deg);
    transition: transform 0.6s var(--ease);
  }
  .mat :global(img) {
    width: 100%;
    height: auto;
    border-radius: 1px;
  }
  .hero__art:hover .mat {
    transform: rotate(0deg);
  }
  .hero__art figcaption {
    margin-top: 1rem;
    text-align: center;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--ink-muted);
  }

  .hero__scroll {
    position: absolute;
    left: 50%;
    bottom: 1.4rem;
    transform: translateX(-50%);
    width: 26px;
    height: 42px;
    border: 1.5px solid var(--ink-soft);
    border-radius: 14px;
    display: grid;
    place-items: start center;
  }
  .hero__scroll span {
    width: 4px;
    height: 8px;
    margin-top: 7px;
    border-radius: 2px;
    background: var(--terracotta);
    animation: drop 1.8s var(--ease) infinite;
  }
  @keyframes drop {
    0% {
      opacity: 0;
      transform: translateY(0);
    }
    30% {
      opacity: 1;
    }
    70% {
      opacity: 1;
      transform: translateY(12px);
    }
    100% {
      opacity: 0;
      transform: translateY(14px);
    }
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
      min-height: 0;
      gap: 2.5rem;
    }
    .hero__lead {
      margin-inline: auto;
    }
    .hero__actions {
      justify-content: center;
    }
    .hero__art {
      order: -1;
      max-width: 460px;
      margin-inline: auto;
    }
    .hero__scroll {
      display: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__scroll span {
      animation: none;
    }
    .mat {
      transform: none;
    }
  }
</style>
