---
import { Image } from 'astro:assets';
// Placeholder portrait — a signature Santa Barbara piece stands in until Wade
// provides a photo of himself. Swap `portrait` for his headshot when available.
import portrait from '../assets/paintings/IMG_2463.jpg';
---

<section id="story" class="story">
  <div class="wrap story__inner">
    <figure class="story__portrait reveal">
      <div class="mat">
        <Image
          src={portrait}
          alt="Red Tiles and Bell Tower — a Santa Barbara street in watercolor by Wade Norman"
          widths={[420, 700]}
          sizes="(max-width: 820px) 80vw, 440px"
          loading="lazy"
        />
      </div>
      <figcaption>A painter of the Santa Barbara light</figcaption>
    </figure>

    <div class="story__text reveal">
      <p class="kicker">The Artist</p>
      <h2>Painting the coast<br />he calls home</h2>
      <hr class="rule" />

      <p>
        Wade Norman is a watercolor painter based in Santa Barbara, California. His
        work follows the California coast — the harbors and fishing boats, the
        headlands and breaking surf, the golden foothills that roll down to the
        sea — and wanders beyond it, to alpine lakes, quiet country roads, and the
        tiled rooftops of far-off seaside towns.
      </p>
      <p>
        He paints in the classic watercolor tradition: loose, luminous washes laid
        down wet and quick, letting the white of the paper carry the light. Some
        pieces are painted from life along the shore; others begin with a memory or
        a mood and, as Wade likes to say, invite you to <em>let your imagination
        go.</em>
      </p>
      <p>
        With each new painting he shares, a community of followers has come to know
        his eye for light and his warm, storytelling spirit. Every piece is a small
        invitation — to slow down, look closely, and imagine your way into the scene.
      </p>

      <blockquote class="story__quote">
        “Let your imagination go.”
        <cite>— Wade Norman</cite>
      </blockquote>

      <p class="signature" aria-hidden="true">W.&nbsp;Norman</p>
    </div>
  </div>
</section>

<style>
  .story {
    background:
      linear-gradient(180deg, var(--paper), var(--paper-warm));
  }
  .story__inner {
    display: grid;
    grid-template-columns: 0.85fr 1.05fr;
    gap: clamp(2.5rem, 6vw, 5.5rem);
    align-items: center;
  }

  .story__portrait {
    margin: 0;
  }
  .story__portrait .mat {
    background: #fdfaf3;
    padding: clamp(0.9rem, 1.8vw, 1.5rem);
    border-radius: var(--radius);
    box-shadow:
      0 18px 40px -20px rgba(43, 41, 36, 0.5),
      0 3px 10px -6px rgba(43, 41, 36, 0.3);
    transform: rotate(-1deg);
  }
  .story__portrait .mat :global(img) {
    width: 100%;
    height: auto;
  }
  .story__portrait figcaption {
    margin-top: 1.1rem;
    text-align: center;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-muted);
  }

  .story__quote {
    margin: 2.2rem 0 1.5rem;
    padding-left: 1.4rem;
    border-left: 3px solid var(--terracotta);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    line-height: 1.3;
    color: var(--ink);
  }
  .story__quote cite {
    display: block;
    margin-top: 0.6rem;
    font-size: 1rem;
    font-style: normal;
    color: var(--ink-muted);
  }

  .signature {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 2rem;
    color: var(--coast-deep);
    opacity: 0.85;
    margin: 0.5rem 0 0;
    transform: rotate(-4deg);
    transform-origin: left center;
  }

  @media (max-width: 820px) {
    .story__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .story__portrait {
      max-width: 380px;
      margin-inline: auto;
    }
  }
</style>
