---
import Base from '../../layouts/Base.astro';
import Story from '../../components/Story.astro';
import Gallery from '../../components/Gallery.astro';
import Rep from '../../components/Rep.astro';
import Footer from '../../components/Footer.astro';
import artists from '../../data/artists.json';

export function getStaticPaths() {
  return artists.map((a) => ({ params: { slug: a.slug }, props: { artist: a } }));
}

const { artist } = Astro.props;
---

<Base
  title={`${artist.name} — State Street Gallery of Fine Art`}
  description={`${artist.name}, ${artist.medium.toLowerCase()} painter — ${artist.blurb} Shown at State Street Gallery of Fine Art, Santa Barbara.`}
  skipTo="#gallery"
  skipLabel="Skip to the paintings"
>
  <nav class="topbar" aria-label="Gallery">
    <div class="wrap topbar__inner">
      <a class="topbar__back" href="/">← State Street Gallery of Fine Art</a>
      <span class="topbar__artist">{artist.name}</span>
    </div>
  </nav>

  <main id="main-content">
    <Story />
    <Gallery artist={artist.name} />
    <Rep variant="panel" />
  </main>

  <Footer />
</Base>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(247, 242, 232, 0.9);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--ink-soft);
  }
  .topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.85rem;
  }
  .topbar__back {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.92rem;
    letter-spacing: 0.01em;
    color: var(--ink);
    text-decoration: none;
  }
  .topbar__back:hover {
    color: var(--terracotta-deep);
  }
  .topbar__artist {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--ink-muted);
  }
  @media (max-width: 560px) {
    .topbar__artist {
      display: none;
    }
  }
</style>
