---
import Base from '../layouts/Base.astro';
import Rep from '../components/Rep.astro';
import Footer from '../components/Footer.astro';
import { getImage } from 'astro:assets';
import artists from '../data/artists.json';
import paintings from '../data/paintings.json';

// Prepared painting images + artist portraits, optimized at build time.
const paintingAssets = import.meta.glob('../assets/paintings/*.jpg', {
  eager: true,
  import: 'default',
});
const artistAssets = import.meta.glob('../assets/artist/*.jpg', {
  eager: true,
  import: 'default',
});

const titleOf = Object.fromEntries(paintings.map((p) => [p.file, p.title]));

// Artist buttons (top of the page).
const artistCards = await Promise.all(
  artists.map(async (a) => {
    const src = artistAssets[`../assets/artist/${a.photo}`];
    if (!src) throw new Error(`Missing artist photo ${a.photo}`);
    const img = await getImage({ src, width: 320, height: 320, fit: 'cover', format: 'webp', quality: 78 });
    return { ...a, img: img.src };
  })
);

// Four featured paintings across the screen (pulled from each artist's picks).
const featuredFiles = artists.flatMap((a) => a.featured).slice(0, 4);
const featured = await Promise.all(
  featuredFiles.map(async (file) => {
    const src = paintingAssets[`../assets/paintings/${file}`];
    if (!src) throw new Error(`Missing featured painting ${file}`);
    const img = await getImage({ src, width: 720, height: 960, fit: 'cover', format: 'webp', quality: 80 });
    return { file, title: titleOf[file] ?? '', src: img.src };
  })
);
---

<Base
  title="State Street Gallery of Fine Art — Santa Barbara"
  description="State Street Gallery of Fine Art — original paintings from Santa Barbara artists. Different artists, different options to decorate your home."
  skipTo="#gallery-artists"
  skipLabel="Skip to the artists"
>
  <header class="masthead">
    <div class="wrap masthead__inner">
      <p class="masthead__eyebrow">Santa Barbara, California</p>
      <h1 class="masthead__title">State&nbsp;Street Gallery<span class="masthead__of"> of </span>Fine&nbsp;Art</h1>
      <hr class="rule rule--center" />
    </div>
  </header>

  <main id="main-content">
    <!-- Artist buttons -->
    <section id="gallery-artists" class="artists">
      <div class="wrap">
        <p class="artists__label reveal">Meet the artists</p>
        <ul class="artists__row reveal">
          {
            artistCards.map((a) => (
              <li class="artist">
                <a class="artist__link" href={`/artists/${a.slug}`}>
                  <span class="artist__ring">
                    <img src={a.img} alt={`Portrait of ${a.name}`} width="160" height="160" loading="eager" />
                  </span>
                  <span class="artist__name">{a.name}</span>
                  <span class="artist__medium">{a.medium}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- Four featured paintings + centered tagline -->
    <section class="showcase">
      <div class="wrap">
        <div class="showcase__grid">
          {
            featured.map((p, i) => (
              <figure class="showcase__item reveal" style={`--i:${i}`}>
                <img src={p.src} alt={p.title} width="720" height="960" loading={i < 2 ? 'eager' : 'lazy'} decoding="async" />
              </figure>
            ))
          }
        </div>

        <p class="showcase__tagline reveal">
          Different artists.<br />
          <span>Different options to decorate your home and the interior of your business.</span>
        </p>
      </div>
    </section>

    <Rep variant="bar" />
  </main>

  <Footer />
</Base>

<style>
  .masthead {
    padding-block: clamp(2.8rem, 7vw, 5rem) clamp(1.5rem, 4vw, 2.5rem);
    text-align: center;
  }
  .masthead__eyebrow {
    margin: 0 0 0.9rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--terracotta);
  }
  .masthead__title {
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 5.2rem);
    line-height: 1.02;
    letter-spacing: 0.01em;
  }
  .masthead__of {
    font-style: italic;
    color: var(--ink-muted);
    font-size: 0.72em;
  }
  .masthead .rule {
    margin-top: clamp(1.2rem, 3vw, 2rem);
  }

  /* ---- artist buttons ---- */
  .artists {
    padding-block: clamp(1.5rem, 4vw, 2.5rem) clamp(2.5rem, 6vw, 4rem);
  }
  .artists__label {
    text-align: center;
    margin: 0 0 1.8rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .artists__row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(1.5rem, 5vw, 3.5rem);
  }
  .artist__link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--ink);
  }
  .artist__ring {
    display: block;
    width: clamp(96px, 16vw, 148px);
    height: clamp(96px, 16vw, 148px);
    border-radius: 50%;
    padding: 5px;
    background: var(--paper);
    border: 1px solid var(--ink-soft);
    box-shadow: 0 12px 28px -18px rgba(43, 41, 36, 0.55);
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease), border-color 0.35s var(--ease);
  }
  .artist__ring img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }
  .artist__link:hover .artist__ring {
    transform: translateY(-4px);
    border-color: var(--terracotta);
    box-shadow: 0 18px 34px -18px rgba(43, 41, 36, 0.6);
  }
  .artist__name {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.2vw, 1.55rem);
    line-height: 1.1;
  }
  .artist__medium {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--terracotta);
  }

  /* ---- featured paintings + tagline ---- */
  .showcase {
    padding-bottom: clamp(3rem, 7vw, 5rem);
  }
  .showcase__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(0.8rem, 2vw, 1.6rem);
  }
  .showcase__item {
    margin: 0;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--radius);
    background: #fdfaf3;
    box-shadow: 0 14px 30px -20px rgba(43, 41, 36, 0.55);
    transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease);
  }
  .showcase__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .showcase__item:hover {
    transform: translateY(-5px);
    box-shadow: 0 22px 40px -20px rgba(43, 41, 36, 0.6);
  }

  .showcase__tagline {
    text-align: center;
    margin: clamp(2.5rem, 6vw, 4rem) auto 0;
    max-width: 30ch;
    font-family: var(--font-serif);
    font-size: clamp(1.7rem, 4vw, 2.9rem);
    line-height: 1.15;
    color: var(--ink);
  }
  .showcase__tagline span {
    color: var(--terracotta-deep);
    font-style: italic;
  }

  @media (max-width: 720px) {
    .showcase__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .showcase__item:hover,
    .artist__link:hover .artist__ring {
      transform: none;
    }
  }
</style>
